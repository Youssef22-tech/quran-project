<%- layout('layouts/boilerplate') %>
    <link rel="stylesheet" href="/css/dashboard/dashboard.css">
    <div class="dash-container">

        <header class="header">
            <div class="user-info">
                <h1>أهلاً، <%= user.username %>
                </h1>
                <p>إليك ملخص تقدمك في حفظ القرآن الكريم</p>
            </div>
            <a href="/plan/new" class="btn-primary">إضافة خطة جديدة</a>
        </header>

        <section class="stats-grid">
            <div class="mini-card">
                <span class="label">إجمالي الخطط</span>
                <span class="value">
                    <%= plans.length %>
                </span>
            </div>
            <div class="mini-card success">
                <span class="label">إجمالي الآيات المنجزة</span>
                <span class="value">
                    <%= plans.reduce((s, p)=> s + (p.completedAyahs || 0), 0) %>
                </span>
            </div>
            <div class="mini-card warning">
                <span class="label">أطول سلسلة إنجاز (Streak)</span>
                <span class="value">
                    <%= plans.length> 0 ? Math.max(...plans.map(p => p.longestStreak || 0)) : 0 %> يوماً
                </span>
            </div>
        </section>

        <section class="plans-list">
            <div class="section-header" onclick="toggleSection('plans-content', this)">
                <h2 class="section-title">خططك الحالية</h2>
                <button class="toggle-btn" aria-label="إخفاء / إظهار">
                    <span class="toggle-icon">−</span>
                </button>
            </div>

            <div id="plans-content">
                <% if (plans.length===0) { %>
                    <div class="empty-state">
                        <p>لا توجد خطط حفظ نشطة حالياً. ابدأ رحلتك الآن بإضافة خطة جديدة.</p>
                    </div>
                    <% } %>

                        <% plans.forEach(plan=> { %>
                            <div class="plan-item">
                                <div class="plan-info">
                                    <div class="plan-text">
                                        <h3>
                                            <%= plan.surahName %>
                                        </h3>
                                        <p class="ayah-range">المدى: من آية <%= plan.startAyah %> إلى <%= plan.endAyah
                                                    %>
                                        </p>
                                    </div>

                                    <div class="plan-progress">
                                        <div class="progress-labels">
                                            <span>التقدم</span>
                                            <span>
                                                <%= plan.progress %>%
                                            </span>
                                        </div>
                                        <div class="progress-bar-bg">
                                            <div class="progress-bar-fill" style="width: <%= plan.progress %>%">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="plan-actions">
                                    <div class="main-buttons">
                                        <a href="/plan/<%= plan._id %>" class="btn-action continue">متابعة الورد
                                            اليومي</a>
                                        <a href="/plan/<%= plan._id %>/review" class="btn-action review">مراجعة
                                            الماضي</a>
                                    </div>

                                    <form action="/plan/<%= plan._id %>/delete" method="POST" class="delete-form">
                                        <button type="submit" class="btn-delete"
                                            onclick="return confirm('تأكيد حذف الخطة؟ لا يمكن التراجع عن هذا الإجراء.')">
                                            حذف الخطة
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <% }) %>
            </div>
        </section>

        <!-- Thikr -->
        <section class="plans-list mt-4">
            <div class="section-header" onclick="toggleSection('athkar-content', this)">
                <h2 class="section-title">ذكر الساعة</h2>
                <button class="toggle-btn">
                    <span class="toggle-icon">−</span>
                </button>
            </div>

            <div id="athkar-content" class="section-content">

                <% if (todayDhikr) { %>

                    <div class="card shadow-sm border-0 rounded-4 p-4 text-center"">

                                <div class=" mb-3">
                        <span class="badge bg-success-light text-success px-3 py-2">
                            <%= todayDhikr.category %>
                        </span>
                    </div>

                    <h4 class="quran-font mb-3">
                        <%= todayDhikr.text %>
                    </h4>

                    <p class="text-muted small">
                        <%= todayDhikr.virtue %>
                    </p>

                    <button class="btn btn-outline-success mt-3" onclick="copyDhikr()">
                        نسخ الذكر
                    </button>

            </div>

            <% } %>


    </div>
    </section>


    <section class="plans-list mt-4">
        <div class="section-header" onclick="toggleSection('question-content', this)">
            <h2 class="section-title">سؤال اليوم</h2>
            <button class="toggle-btn">
                <span class="toggle-icon">−</span>
            </button>
        </div>

        <div id="question-content" class="section-content"">

                        <% if (todayQuestion) { %>

                            <div class=" card shadow-sm border-0 rounded-4 p-4"">

            <h5 class="fw-bold mb-4 text-center">
                <%= todayQuestion.question %>
            </h5>

            <div class="options-container" style="display: flex; flex-direction: row; min-height: 6vh;">

                <% todayQuestion.options.forEach((opt, i)=> { %>
                    <button class="btn btn-outline-dark w-100 mb-2 option-btn"
                        onclick="checkAnswer(this, <%= i %>, <%= todayQuestion.answer %>)">
                        <%= opt %>
                    </button>
                    <% }) %>

            </div>

            <div id="question-feedback" class="mt-3 fw-bold text-center"></div>

            <div id="question-explanation" class="text-muted small mt-2 text-center d-none">
                <%= todayQuestion.explanation %>
            </div>

        </div>

        <% } %>

            </div>
    </section>
    </div>

    <script src="/js/dashboard/dashboard.js"></script>
    </body>