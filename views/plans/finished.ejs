<!DOCTYPE html>
<html lang="ar">

<head>
    <meta charset="UTF-8">
    <title>Finished Plan</title>
    <link rel="stylesheet" href="/css/plans/finished.css">
</head>

<body>
    <div class="card">
        <h1>مبروك!</h1>

        <p>
            لقد أنهيت خطة حفظ سورة
            <strong>
                <%= surah.name %>
            </strong>
        </p>

        <p>
